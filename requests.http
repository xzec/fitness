### Register ADMIN (one-time; 409 after)
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}",
  "role": "ADMIN"
}

### Register USER (one-time; 409 after)
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{userEmail}}",
  "password": "{{userPassword}}",
  "role": "USER"
}

### Login ADMIN → saves {{adminToken}}
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

> {%
  client.global.set("adminToken", response.body.data.token);
%}

### Login USER → saves {{userToken}}
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{userEmail}}",
  "password": "{{userPassword}}"
}

> {%
  client.global.set("userToken", response.body.data.token);
%}

### GET /exercises — public
GET {{baseUrl}}/exercises

### POST /exercises — ADMIN happy path → 201, saves {{createdExerciseID}}
POST {{baseUrl}}/admin/exercises
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Push-up",
  "difficulty": "EASY",
  "programID": {{programID}}
}

> {%
  client.global.set("createdExerciseID", response.body.data.id);
%}

### POST /exercises — no token → 401
POST {{baseUrl}}/admin/exercises
Content-Type: application/json

{
  "name": "Push-up",
  "difficulty": "EASY",
  "programID": {{programID}}
}

### POST /exercises — USER role → 403
POST {{baseUrl}}/admin/exercises
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "name": "Push-up",
  "difficulty": "EASY",
  "programID": {{programID}}
}

### POST /exercises — bad body (missing difficulty) → 400
POST {{baseUrl}}/admin/exercises
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "X",
  "programID": {{programID}}
}

### POST /exercises — unknown program → 404
POST {{baseUrl}}/admin/exercises
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "X",
  "difficulty": "EASY",
  "programID": 9999
}

### PATCH /exercises/:id — ADMIN → 200
PATCH {{baseUrl}}/admin/exercises/{{createdExerciseID}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Push-up (updated)",
  "difficulty": "MEDIUM"
}

### PATCH /exercises/:id — USER → 403
PATCH {{baseUrl}}/admin/exercises/{{createdExerciseID}}
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "name": "nope"
}

### PATCH /exercises/:id — unknown exercise → 404
PATCH {{baseUrl}}/admin/exercises/9999
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "x"
}

### PATCH /exercises/:id — unknown programID → 404
PATCH {{baseUrl}}/admin/exercises/{{createdExerciseID}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "programID": 9999
}

### DELETE /exercises/:id — ADMIN → 204, already deleted → 404
DELETE {{baseUrl}}/admin/exercises/{{createdExerciseID}}
Authorization: Bearer {{adminToken}}

### DELETE /exercises/:id — USER → 403
DELETE {{baseUrl}}/admin/exercises/1
Authorization: Bearer {{userToken}}

### GET /admin/users — ADMIN → 200, saves {{targetUserID}} (last user in list)
GET {{baseUrl}}/admin/users
Authorization: Bearer {{adminToken}}

> {%
  const list = response.body.data;
  client.global.set("targetUserID", list[list.length - 1].id);
%}

### GET /admin/users — no token → 401
GET {{baseUrl}}/admin/users

### GET /admin/users — USER → 403
GET {{baseUrl}}/admin/users
Authorization: Bearer {{userToken}}

### GET /admin/users/:id — ADMIN → 200
GET {{baseUrl}}/admin/users/{{targetUserID}}
Authorization: Bearer {{adminToken}}

### GET /admin/users/:id — unknown id → 404
GET {{baseUrl}}/admin/users/999999
Authorization: Bearer {{adminToken}}

### PATCH /admin/users/:id — ADMIN updates editable fields → 200
PATCH {{baseUrl}}/admin/users/{{targetUserID}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Alice",
  "surname": "Doe",
  "nickName": "ali",
  "age": 30,
  "role": "USER"
}

### PATCH /admin/users/:id — email is stripped, remains unchanged → 200
PATCH {{baseUrl}}/admin/users/{{targetUserID}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "email": "hacked@x.y",
  "nickName": "ali2"
}

### PATCH /admin/users/:id — invalid role → 400 zod
PATCH {{baseUrl}}/admin/users/{{targetUserID}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "role": "SUPERADMIN"
}

### PATCH /admin/users/:id — USER → 403
PATCH {{baseUrl}}/admin/users/{{targetUserID}}
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "nickName": "nope"
}

### PATCH /admin/users/:id — unknown id → 404
PATCH {{baseUrl}}/admin/users/999999
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "nickName": "x"
}
